{
  "name": "nothing_dark",
  "mode": "dark",
  "colors": {
    "backgroundBase": "#000000",
    "surfaceBase": "#111111",
    "surfaceRaised": "#1A1A1A",
    "borderSubtle": "#222222",
    "borderVisible": "#333333",
    "textDisplay": "#FFFFFF",
    "textPrimary": "#E8E8E8",
    "textSecondary": "#999999",
    "textDisabled": "#666666",
    "accentSignal": "#D71921",
    "accentSubtle": "#26D71921",
    "valueSuccess": "#4A9E5C",
    "valueWarning": "#D4A843",
    "interactiveLink": "#5B9BF6",
    "dotGridColor": "#333333"
  },
  "typography": {
    "fontFamilyDisplay": "Doto",
    "fontFamilyBody": "Space Grotesk",
    "fontFamilyMono": "Space Mono",
    "displayLarge": {
      "fontSize": 72,
      "lineHeight": 1.0,
      "letterSpacingEm": -0.03
    },
    "displayMedium": {
      "fontSize": 48,
      "lineHeight": 1.05,
      "letterSpacingEm": -0.02
    },
    "displaySmall": {
      "fontSize": 36,
      "lineHeight": 1.1,
      "letterSpacingEm": -0.02
    },
    "headlineMedium": {
      "fontSize": 24,
      "lineHeight": 1.2,
      "letterSpacingEm": -0.01
    },
    "titleMedium": {
      "fontSize": 18,
      "lineHeight": 1.3,
      "letterSpacingEm": 0.0
    },
    "bodyLarge": {
      "fontSize": 16,
      "lineHeight": 1.5,
      "letterSpacingEm": 0.0
    },
    "bodyMedium": {
      "fontSize": 14,
      "lineHeight": 1.5,
      "letterSpacingEm": 0.01
    },
    "labelSmall": {
      "fontSize": 11,
      "lineHeight": 1.2,
      "letterSpacingEm": 0.08
    }
  },
  "spacing": {
    "xs": 4,
    "sm": 8,
    "md": 16,
    "lg": 24,
    "xl": 32,
    "2xl": 48,
    "3xl": 64,
    "4xl": 96
  },
  "radius": {
    "technical": 4,
    "compact": 8,
    "card": 16,
    "pill": 999
  },
  "motion": {
    "microMs": 180,
    "transitionMs": 320,
    "curve": "easeOut"
  },
  "notes": [
    "Accent should be used as a signal, not as a decorative fill.",
    "Prefer spacing and type contrast before adding extra borders.",
    "Mono labels should remain uppercase and tertiary by default."
  ]
}
