{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OptimizationPlan",
  "type": "object",
  "required": [
    "summary",
    "actions"
  ],
  "properties": {
    "summary": {
      "type": "object",
      "properties": {
        "project_name": {
          "type": "string"
        },
        "generated_at": {
          "type": "string"
        },
        "primary_goal": {
          "type": "string"
        }
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "severity",
          "risk",
          "evidence",
          "proposed_action",
          "affected_files",
          "approval_required"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "severity": {
            "type": "string"
          },
          "risk": {
            "type": "string"
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "proposed_action": {
            "type": "string"
          },
          "affected_files": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "approval_required": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
