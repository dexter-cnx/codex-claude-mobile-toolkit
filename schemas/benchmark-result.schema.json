{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BenchmarkResult",
  "type": "object",
  "required": [
    "project",
    "environment",
    "runs"
  ],
  "properties": {
    "project": {
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "platforms": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "environment": {
      "type": "object",
      "properties": {
        "flutter_version": {
          "type": "string"
        },
        "dart_version": {
          "type": "string"
        },
        "host_os": {
          "type": "string"
        }
      }
    },
    "runs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "command",
          "duration_ms",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "command": {
            "type": "string"
          },
          "duration_ms": {
            "type": "number"
          },
          "status": {
            "type": "string",
            "enum": [
              "ok",
              "failed",
              "skipped"
            ]
          }
        }
      }
    }
  }
}
