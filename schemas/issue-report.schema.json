{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "IssueReport",
  "type": "object",
  "required": [
    "id",
    "title",
    "severity",
    "risk",
    "evidence"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "severity": {
      "type": "string"
    },
    "risk": {
      "type": "string"
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
