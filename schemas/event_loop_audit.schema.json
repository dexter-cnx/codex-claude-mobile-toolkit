{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EventLoopAuditReport",
  "type": "object",
  "required": [
    "executive_summary",
    "top_issues",
    "findings",
    "quick_wins",
    "refactor_plan",
    "final_verdict"
  ],
  "properties": {
    "executive_summary": {
      "type": "object",
      "required": ["overall_health", "strengths", "risks", "confidence"],
      "properties": {
        "overall_health": { "type": "string" },
        "strengths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "risks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "confidence": {
          "type": "string",
          "enum": ["high", "medium", "low"]
        }
      }
    },
    "top_issues": {
      "type": "array",
      "maxItems": 5,
      "items": { "$ref": "#/$defs/finding" }
    },
    "findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/finding" }
    },
    "quick_wins": {
      "type": "array",
      "items": { "type": "string" }
    },
    "refactor_plan": {
      "type": "object",
      "required": ["phase_1", "phase_2", "phase_3"],
      "properties": {
        "phase_1": {
          "type": "array",
          "items": { "type": "string" }
        },
        "phase_2": {
          "type": "array",
          "items": { "type": "string" }
        },
        "phase_3": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "good_patterns": {
      "type": "array",
      "items": { "type": "string" }
    },
    "final_verdict": {
      "type": "object",
      "required": ["summary", "event_loop_health"],
      "properties": {
        "summary": { "type": "string" },
        "event_loop_health": {
          "type": "string",
          "enum": ["strong", "acceptable", "mixed", "weak"]
        }
      }
    }
  },
  "$defs": {
    "finding": {
      "type": "object",
      "required": [
        "title",
        "severity",
        "where",
        "problem",
        "why_it_matters",
        "recommended_fix",
        "confidence"
      ],
      "properties": {
        "title": { "type": "string" },
        "severity": {
          "type": "string",
          "enum": ["Must Fix", "Should Improve", "Optional"]
        },
        "where": {
          "type": "object",
          "required": ["file", "symbol"],
          "properties": {
            "file": { "type": "string" },
            "symbol": { "type": "string" }
          }
        },
        "problem": { "type": "string" },
        "why_it_matters": { "type": "string" },
        "recommended_fix": { "type": "string" },
        "example_patch": { "type": "string" },
        "confidence": {
          "type": "string",
          "enum": ["High", "Medium", "Low"]
        }
      }
    }
  }
}
